        ];

        const baseUrl = "https://raw.githubusercontent.com/6nwbbbwhpz-lgtm/----/main/";
        const galleryEl = document.getElementById('gallery');
        let cart = [];

        // Генерируем 55 карточек
        for (let i = 1; i <= 55; i++) {
            let price = 3500 + ((i % 4) * 500); 
            let desc = "Авторский букет";
            let fileName = uploadedPhotos[i % uploadedPhotos.length];
            
            const card = document.createElement('div');
            card.className = 'product-card';
            card.innerHTML = `
                <img src="${baseUrl}${encodeURI(fileName)}" alt="Букет ${i}" onerror="this.src='https://placehold.co/200x150/fff0f2/d63384?text=Фото'">
                <div class="product-title">Букет №${i}</div>
                <div style="font-size: 11px; color: #777; margin: 4px 0;">${desc}</div>
                <div class="product-price">${price} руб.</div>
                <button class="add-to-cart-btn" onclick="addToCart(${i}, 'Букет №${i}', ${price})">В корзину</button>
            `;
            galleryEl.appendChild(card);
        }

        function addToCart(id, name, price) {
            const inCart = cart.find(item => item.id === id);
            if (inCart) inCart.count++;
            else cart.push({ id, name, price, count: 1 });
            updateCartUI();
        }

        function updateCartUI() {
            const cartItemsEl = document.getElementById('cart-items');
            const cartTotalEl = document.getElementById('cart-total');
            cartItemsEl.innerHTML = '';
            let total = 0;
            cart.forEach(item => {
                total += item.price * item.count;
                cartItemsEl.innerHTML += `<div class="cart-item"><span>🌸 ${item.name} (x${item.count})</span><span>${item.price * item.count} руб.</span></div>`;
            });
            cartTotalEl.innerText = `Итого: ${total} руб.`;
        }

        function sendOrder(e) {
            e.preventDefault();
            const city = document.getElementById('city-select').value;
            if (cart.length === 0) { alert('Пожалуйста, выберите товар!'); return; }
            let msg = `Здравствуйте! Мой заказ:\n📍 Город: ${city}\n\n`;
            let total = 0;
            cart.forEach(i => { msg += `• ${i.name} — ${i.price * i.count} руб.\n`; total += i.price * i.count; });
            window.open(`https://wa.me/${myPhoneNumber}?text=${encodeURIComponent(msg)}`, '_blank');
        }
    </script>
