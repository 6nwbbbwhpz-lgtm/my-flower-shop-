        const myPhoneNumber = "79280126881"; 

        const uploadedPhotos = [
            "PHOTO-2025-06-07-00-47-47.jpeg", "PHOTO-2025-06-07-00-54-49.jpeg", "PHOTO-2025-06-07-01-03-23.jpeg",
            "PHOTO-2025-06-26-23-37-17.jpeg", "PHOTO-2025-06-26-23-37-26.jpeg", "PHOTO-2025-06-29-01-24-00 5.jpeg",
            "PHOTO-2025-06-29-01-24-00 6.jpeg", "PHOTO-2025-06-29-01-24-00 7.jpeg", "PHOTO-2025-06-29-01-24-01 2.jpeg",
            "PHOTO-2025-06-29-01-24-01 3.jpeg", "PHOTO-2025-06-29-01-24-01 4.jpeg", "PHOTO-2025-06-29-01-24-01.jpeg",
            "PHOTO-2025-06-29-16-03-20.jpeg", "PHOTO-2025-06-29-16-04-06.jpeg", "PHOTO-2025-06-29-16-26-51.jpeg",
            "PHOTO-2025-06-29-16-55-32.jpeg", "PHOTO-2025-06-29-16-56-11.jpeg", "PHOTO-2025-06-29-16-58-52.jpeg",
            "PHOTO-2025-06-29-17-05-25.jpeg", "PHOTO-2025-07-06-21-46-41.jpeg", "PHOTO-2025-07-06-22-14-19.jpeg",
            "PHOTO-2025-07-06-22-16-25.jpeg", "PHOTO-2025-07-06-22-17-39.jpeg", "PHOTO-2025-07-08-18-00-15.jpeg",
            "PHOTO-2025-07-12-21-35-36.jpeg", "PHOTO-2025-07-13-17-43-49 2.jpeg", "PHOTO-2025-07-13-17-43-49 3.jpeg",
